{
  "cases": [
    {
      "name": "none_literal",
      "code": "value = None",
      "expr": "value",
      "expected": {
        "kind": "None",
        "type": "None"
      }
    },
    {
      "name": "bool_true",
      "code": "value = True",
      "expr": "value",
      "expected": {
        "kind": "Bool",
        "type": "builtins.bool",
        "b": true
      }
    },
    {
      "name": "int_small",
      "code": "value = 42",
      "expr": "value",
      "expected": {
        "kind": "Int",
        "type": "builtins.int",
        "i": 42
      }
    },
    {
      "name": "string_text",
      "code": "value = 'hello world'",
      "expr": "value",
      "expected": {
        "kind": "String",
        "type": "builtins.str",
        "text": "hello world"
      }
    },
    {
      "name": "tuple_mixed",
      "code": "value = ('alpha', 7)",
      "expr": "value",
      "expected": {
        "kind": "Tuple",
        "type": "builtins.tuple",
        "elements": [
          {
            "kind": "String",
            "type": "builtins.str",
            "text": "alpha"
          },
          {
            "kind": "Int",
            "type": "builtins.int",
            "i": 7
          }
        ]
      }
    },
    {
      "name": "list_numbers",
      "code": "value = [1, 2, 3]",
      "expr": "value",
      "expected": {
        "kind": "Sequence",
        "type": "builtins.list",
        "is_slice": false,
        "elements": [
          {
            "kind": "Int",
            "type": "builtins.int",
            "i": 1
          },
          {
            "kind": "Int",
            "type": "builtins.int",
            "i": 2
          },
          {
            "kind": "Int",
            "type": "builtins.int",
            "i": 3
          }
        ]
      }
    },
    {
      "name": "dict_mixed_keys",
      "code": "value = {'a': 1, 2: 'b'}",
      "expr": "value",
      "expected": {
        "kind": "Sequence",
        "type": "builtins.dict",
        "is_slice": false,
        "elements": [
          {
            "kind": "Tuple",
            "type": "builtins.tuple",
            "elements": [
              {
                "kind": "String",
                "type": "builtins.str",
                "text": "a"
              },
              {
                "kind": "Int",
                "type": "builtins.int",
                "i": 1
              }
            ]
          },
          {
            "kind": "Tuple",
            "type": "builtins.tuple",
            "elements": [
              {
                "kind": "Int",
                "type": "builtins.int",
                "i": 2
              },
              {
                "kind": "String",
                "type": "builtins.str",
                "text": "b"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "custom_repr_raw",
      "code": "class ReprObj:\n    def __repr__(self):\n        return '<ReprObj>'\nvalue = ReprObj()",
      "expr": "value",
      "expected": {
        "kind": "Struct",
        "type": "codetracer.repr-fallback",
        "fields": [
          {
            "name": "repr",
            "value": {
              "kind": "Raw",
              "type": "<fixture_module>.ReprObj",
              "r": "<ReprObj>"
            }
          },
          {
            "name": "total_length",
            "value": {
              "kind": "Int",
              "type": "builtins.int",
              "i": 9
            }
          },
          {
            "name": "truncated",
            "value": {
              "kind": "Bool",
              "type": "builtins.bool",
              "b": false
            }
          },
          {
            "name": "handler",
            "value": {
              "kind": "String",
              "type": "builtins.str",
              "text": "<none>"
            }
          },
          {
            "name": "reason",
            "value": {
              "kind": "String",
              "type": "builtins.str",
              "text": "no_handler"
            }
          }
        ]
      }
    }
  ]
}