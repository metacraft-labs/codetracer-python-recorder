{
  "cases": [
    {
      "name": "nested_structures",
      "code": "value = {\"nums\": [1, [2, 3]], \"inner\": {\"a\": True}}",
      "expr": "value",
      "expected": {
        "kind": "Sequence",
        "type": "builtins.dict",
        "is_slice": false,
        "elements": [
          {
            "kind": "Tuple",
            "type": "builtins.tuple",
            "elements": [
              {
                "kind": "String",
                "type": "builtins.str",
                "text": "nums"
              },
              {
                "kind": "Sequence",
                "type": "builtins.list",
                "is_slice": false,
                "elements": [
                  {
                    "kind": "Int",
                    "type": "builtins.int",
                    "i": 1
                  },
                  {
                    "kind": "Sequence",
                    "type": "builtins.list",
                    "is_slice": false,
                    "elements": [
                      {
                        "kind": "Int",
                        "type": "builtins.int",
                        "i": 2
                      },
                      {
                        "kind": "Int",
                        "type": "builtins.int",
                        "i": 3
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "kind": "Tuple",
            "type": "builtins.tuple",
            "elements": [
              {
                "kind": "String",
                "type": "builtins.str",
                "text": "inner"
              },
              {
                "kind": "Sequence",
                "type": "builtins.dict",
                "is_slice": false,
                "elements": [
                  {
                    "kind": "Tuple",
                    "type": "builtins.tuple",
                    "elements": [
                      {
                        "kind": "String",
                        "type": "builtins.str",
                        "text": "a"
                      },
                      {
                        "kind": "Bool",
                        "type": "builtins.bool",
                        "b": true
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "name": "datetime_raw",
      "code": "import datetime\nvalue = datetime.datetime(2024, 1, 2, 3, 4, 5)",
      "expr": "value",
      "expected": {
        "kind": "Raw",
        "type": "datetime.datetime",
        "r": "2024-01-02 03:04:05"
      }
    },
    {
      "name": "repr_failure",
      "code": "class BadStr:\n    def __str__(self):\n        raise RuntimeError('boom')\nvalue = BadStr()",
      "expr": "value",
      "expected": {
        "kind": "Error",
        "type": "<fixture_module>.BadStr",
        "msg": "<unrepr>"
      }
    }
  ]
}